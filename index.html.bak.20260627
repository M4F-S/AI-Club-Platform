<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>42 Berlin AI Club</title>
  <meta name="description" content="A student-led, vendor-neutral community at 42 Berlin helping members learn, explore, and build with AI responsibly.">
  <meta name="theme-color" content="#f43f5e">
  <meta property="og:title" content="42 Berlin AI Club">
  <meta property="og:description" content="Student-led AI community at 42 Berlin. Learn, build, and explore AI responsibly.">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://mysophia.tech/ai-club/">
  <link rel="canonical" href="https://mysophia.tech/ai-club/">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/ai-club/assets/ai-club.css?v=11">
</head>
<body>
  <div class="gradient-orb orb-1" aria-hidden="true"></div>
  <div class="gradient-orb orb-2" aria-hidden="true"></div>
  <div class="gradient-orb orb-3" aria-hidden="true"></div>
  <canvas id="canvas-bg" aria-hidden="true"></canvas>

  <header>
    <nav>
      <a href="/ai-club/" class="logo">
        <div class="logo-icon" aria-hidden="true">
          <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <linearGradient id="phoenixGrad" x1="0%" y1="100%" x2="0%" y2="0%">
                <stop offset="0%" style="stop-color:#c65d3b"/>
                <stop offset="50%" style="stop-color:#f43f5e"/>
                <stop offset="100%" style="stop-color:#f2cc8f"/>
              </linearGradient>
            </defs>
            <path d="M16 2 C13 6, 12 11, 14 15 C11 13, 7 14, 5 17 C4 19, 5 22, 8 23 C7 25, 8 27, 10 28 C12 29, 14 28, 15 26 C15 28, 16 30, 17 30 C18 30, 18 28, 18 26 C19 28, 21 29, 23 28 C25 27, 26 25, 25 23 C28 22, 29 19, 27 17 C25 14, 21 13, 18 15 C20 11, 19 6, 16 2 Z" fill="url(#phoenixGrad)"/>
            <path d="M16 6 C14 9, 13 13, 14 16 C12 15, 10 15, 9 17 C8 18, 9 20, 11 21 C10 22, 11 23, 12 24 C13 24, 14 23, 15 22 C15 24, 16 25, 17 25 C18 25, 18 24, 18 22 C19 23, 20 24, 21 24 C22 23, 23 22, 22 21 C24 20, 25 18, 24 17 C23 15, 21 15, 19 16 C20 13, 19 9, 16 6 Z" fill="#faf3f0" opacity="0.4"/>
          </svg>
        </div>
        <span>42 Berlin AI Club</span>
      </a>
      <button class="mobile-menu-toggle" aria-label="Toggle menu" aria-expanded="false">&#9776;</button>
      <ul class="nav-links">
        <li><a href="/ai-club/">Home</a></li>
        <li><a href="/ai-club/become-member.html">Membership</a></li>
        <li><a href="/ai-club/become-partner.html">Partners</a></li>
        <li><a href="/ai-club/login.html">Member Login</a></li>
        <li><a href="/ai-club/become-member.html" class="nav-cta">Join us</a></li>
      </ul>
    </nav>
  </header>

  <main>
    <section class="hero">
      <div class="hero-content">
        <div class="revolve-ring" aria-hidden="true"></div>
        <div class="revolve-ring revolve-ring-2" aria-hidden="true"></div>
        <h1 class="animate-on-scroll">42 Berlin <span class="text-gradient">AI Club</span></h1>
        <p class="animate-on-scroll stagger-1">Learn, build, and use AI responsibly — together. A student-led, vendor-neutral community dedicated to helping members explore and build with artificial intelligence in a responsible and conscious way.</p>
        <div class="hero-actions animate-on-scroll stagger-2">
          <a href="/ai-club/become-member.html" class="btn btn-primary">Become a member</a>
          <a href="/ai-club/become-partner.html" class="btn btn-secondary">Partner with us</a>
        </div>
      </div>
    </section>

    <section class="stats" aria-label="Club stats" id="stats">
      <div class="stat-card animate-on-scroll">
        <div class="stat-number" data-stat="members">-</div>
        <div class="stat-label">Members</div>
      </div>
      <div class="stat-card animate-on-scroll stagger-1">
        <div class="stat-number" data-stat="events">-</div>
        <div class="stat-label">Events</div>
      </div>
      <div class="stat-card animate-on-scroll stagger-2">
        <div class="stat-number" data-stat="projects">-</div>
        <div class="stat-label">Projects</div>
      </div>
      <div class="stat-card animate-on-scroll stagger-3">
        <div class="stat-number" data-stat="workshops">-</div>
        <div class="stat-label">Workshops</div>
      </div>
    </section>

    <section id="about" class="section-alt">
      <h2 class="section-title animate-on-scroll">About the club</h2>
      <p class="section-subtitle animate-on-scroll">Our mission, principles, and why we exist.</p>
      <div class="about-grid">
        <div class="card about-text animate-on-scroll">
          <h2>Our mission</h2>
          <p>We create a space where students can develop practical AI skills through workshops, peer learning, project demos, study sessions, and collaborative building, while also understanding how to use AI thoughtfully, ethically, and effectively in everyday coding and problem-solving.</p>
          <p>The club is open to students of all levels and supports learning, experimentation, and community growth at 42 Berlin, in alignment with the school’s peer-to-peer model and community standards.</p>
        </div>
        <div class="card about-text animate-on-scroll stagger-1">
          <h2>Club principles</h2>
          <ul class="principles-list">
            <li>We are student-led and community-oriented.</li>
            <li>We focus on learning, experimentation, and responsible AI use.</li>
            <li>We stay vendor-neutral and welcome support from multiple AI organizations.</li>
            <li>We respect 42 Berlin’s community standards and privacy expectations.</li>
            <li>We do not use the club for spam, commercial promotion, or unrelated marketing.</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="what-we-do">
      <h2 class="section-title animate-on-scroll">What we do</h2>
      <p class="section-subtitle animate-on-scroll">Hands-on learning for every level.</p>
      <div class="activities">
        <div class="card activity-card animate-on-scroll">
          <h3>Workshops</h3>
          <p>Host AI workshops for beginners and advanced members.</p>
        </div>
        <div class="card activity-card animate-on-scroll stagger-1">
          <h3>Prompt engineering</h3>
          <p>Run prompt engineering sessions and practical AI tool demos.</p>
        </div>
        <div class="card activity-card animate-on-scroll stagger-2">
          <h3>Projects</h3>
          <p>Build small AI projects together in teams or individually.</p>
        </div>
        <div class="card activity-card animate-on-scroll">
          <h3>Responsible AI</h3>
          <p>Discuss AI safety, responsible use, privacy, and bias.</p>
        </div>
        <div class="card activity-card animate-on-scroll stagger-1">
          <h3>Guest speakers</h3>
          <p>Invite guest speakers, mentors, and industry partners when available.</p>
        </div>
        <div class="card activity-card animate-on-scroll stagger-2">
          <h3>Resources</h3>
          <p>Share resources and best practices for using AI in study, coding, and project work.</p>
        </div>
      </div>
    </section>

    <section id="why" class="section-alt">
      <div class="container-narrow">
        <div class="card about-text animate-on-scroll">
          <h2>Why this club exists</h2>
          <p>AI is becoming a core skill for coding, product building, and problem solving, and many students want a structured place to learn how to use it well. This club helps 42 Berlin students build real practical skills while also understanding the limits, risks, and responsibilities of AI use.</p>
          <p>By combining hands-on learning with responsible guidance, we want to make AI accessible, useful, and safe for the whole community.</p>
        </div>
      </div>
    </section>

    <section>
      <div class="cta-section animate-on-scroll">
        <h2>Join the community</h2>
        <p>Applications are reviewed to confirm 42 Berlin student status. Once approved, you will receive login credentials and access to the member area.</p>
        <div class="hero-actions" style="justify-content: center;">
          <a href="/ai-club/become-member.html" class="btn btn-primary">Apply for membership</a>
          <a href="/ai-club/become-partner.html" class="btn btn-secondary">Become a partner</a>
        </div>
      </div>
    </section>

    <section class="section-alt" id="contact">
      <h2 class="section-title animate-on-scroll">Get in touch</h2>
      <p class="section-subtitle animate-on-scroll">Questions, ideas, or partnership interest? Send us a message.</p>
      <form class="contact-form form-wrapper animate-on-scroll" id="contact-form" action="/ai-club/api/contact" method="POST">
        <div class="form-row">
          <div class="form-group">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" required>
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required>
          </div>
        </div>
        <div class="form-group">
          <label for="message">Message</label>
          <textarea id="message" name="message" required></textarea>
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%;">Send message</button>
        <div class="form-status" id="contact-status"></div>
      </form>
    </section>
  </main>

  <footer>
    <div class="footer-content">
      <div>
        <h4>42 Berlin AI Club</h4>
        <p style="color:#a89894; font-size:0.95rem;">A student-led, vendor-neutral AI community at 42 Berlin.</p>
      </div>
      <div>
        <h4>Explore</h4>
        <a href="/ai-club/">Home</a>
        <a href="/ai-club/become-member.html">Membership</a>
        <a href="/ai-club/become-partner.html">Partners</a>
        <a href="/ai-club/privacy-policy.html">Privacy Policy</a>
      </div>
      <div>
        <h4>Connect</h4>
        <a href="https://42berlin.de" target="_blank" rel="noopener">42 Berlin</a>
      </div>
    </div>
    <div class="footer-bottom">
      &copy; 2026 42 Berlin AI Club. Built by students, for students.
    </div>
  </footer>

  <script src="/ai-club/assets/ai-club.js?v=10"></script>
</body>
</html>
